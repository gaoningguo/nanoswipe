{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "NanoSwipe Omni",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run dev:web",
    "beforeBuildCommand": "npm --prefix ../.. run build:web",
    "devPath": "http://localhost:3333",
    "distDir": "../../web/dist",
    "withGlobalTauri": true
  },
  "tauri": {
    "windows": [
      {
        "title": "NanoSwipe Omni",
        "width": 460,
        "height": 900,
        "minWidth": 380,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "allowlist": {
      "all": true,
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://**", "https://**"]
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.nanoswipe.omni",
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ]
    }
  }
}
