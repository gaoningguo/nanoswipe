{
  "name": "@nanoswipe/capacitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix ../.. run dev:web",
    "build": "npm --prefix ../.. run build:web",
    "build:web": "npm --prefix ../.. run build:web",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npm run build && npx cap sync",
    "build:android": "npm run cap:sync && npm run build:android:debug",
    "build:android:debug": "node scripts/build-android.mjs assembleDebug",
    "build:android:release": "node scripts/build-android.mjs assembleRelease",
    "build:ios": "npm run cap:sync && npx cap build ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  }
}
